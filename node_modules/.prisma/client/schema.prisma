generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  OFFICE
  PROJECT_MANAGER
  TECHNICIAN
}

enum ProjectStatus {
  PLANNED
  ACTIVE
  PAUSED
  COMPLETED
  BILLED
}

enum TimeEntryType {
  WORK
  TRAVEL
  TRAINING
  OFFICE
  OTHER
}

enum TimeEntryStatus {
  RUNNING
  PAUSED
  COMPLETED
}

enum TaskStatus {
  OPEN
  PLANNED
  IN_PROGRESS
  WAITING
  DONE
  ACCEPTED
}

enum TaskPriority {
  LOW
  NORMAL
  HIGH
  CRITICAL
}

enum WeatherCondition {
  SUNNY
  CLOUDY
  RAIN
  SNOW
  STORM
  MIXED
  UNKNOWN
}

model Company {
  id               String            @id @default(uuid())
  name             String
  email            String?
  users            User[]
  customers        Customer[]
  projects         Project[]
  diaryEntries     DiaryEntry[]
  timeEntries      TimeEntry[]
  tasks            Task[]
  documents        Document[]
  materials        Material[]
  materialBookings MaterialBooking[]
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
}

model User {
  id               String            @id @default(uuid())
  companyId        String
  company          Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  email            String
  passwordHash     String
  firstName        String
  lastName         String
  role             Role              @default(TECHNICIAN)
  active           Boolean           @default(true)
  diaryEntries     DiaryEntry[]
  timeEntries      TimeEntry[]
  assignedTasks    Task[]            @relation("TaskAssignee")
  createdTasks     Task[]            @relation("TaskCreator")
  taskComments     TaskComment[]
  documents        Document[]
  materialBookings MaterialBooking[]
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@unique([companyId, email])
  @@index([companyId])
}

model Customer {
  id             String    @id @default(uuid())
  companyId      String
  company        Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  customerNumber String
  name           String
  contactName    String?
  email          String?
  phone          String?
  billingAddress String?
  projects       Project[]
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@unique([companyId, customerNumber])
  @@index([companyId])
}

model Project {
  id               String            @id @default(uuid())
  companyId        String
  company          Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  customerId       String
  customer         Customer          @relation(fields: [customerId], references: [id], onDelete: Restrict)
  projectNumber    String
  name             String
  address          String
  description      String?
  status           ProjectStatus     @default(PLANNED)
  startDate        DateTime?
  endDate          DateTime?
  diaryEntries     DiaryEntry[]
  timeEntries      TimeEntry[]
  tasks            Task[]
  documents        Document[]
  materialBookings MaterialBooking[]
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@unique([companyId, projectNumber])
  @@index([companyId])
  @@index([customerId])
}

model DiaryEntry {
  id          String           @id @default(uuid())
  companyId   String
  company     Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  projectId   String
  project     Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  authorId    String
  author      User             @relation(fields: [authorId], references: [id], onDelete: Restrict)
  entryDate   DateTime
  title       String
  workDone    String
  incidents   String?
  staffCount  Int              @default(1)
  hoursWorked Float?
  weather     WeatherCondition @default(UNKNOWN)
  temperature Float?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  documents   Document[]

  @@index([companyId])
  @@index([projectId, entryDate])
  @@index([authorId])
}

model TimeEntry {
  id             String          @id @default(uuid())
  companyId      String
  company        Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  projectId      String
  project        Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId         String
  taskId         String?
  user           User            @relation(fields: [userId], references: [id], onDelete: Restrict)
  task           Task?           @relation(fields: [taskId], references: [id], onDelete: SetNull)
  startTime      DateTime
  endTime        DateTime?
  status         TimeEntryStatus @default(RUNNING)
  type           TimeEntryType   @default(WORK)
  note           String?
  manuallyEdited Boolean         @default(false)
  breaks         TimeBreak[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([companyId])
  @@index([projectId, startTime])
  @@index([userId, status])
  @@index([taskId])
}

model TimeBreak {
  id          String    @id @default(uuid())
  timeEntryId String
  timeEntry   TimeEntry @relation(fields: [timeEntryId], references: [id], onDelete: Cascade)
  startTime   DateTime
  endTime     DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([timeEntryId])
}

model Task {
  id           String              @id @default(uuid())
  companyId    String
  company      Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  projectId    String
  project      Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title        String
  description  String?
  status       TaskStatus          @default(OPEN)
  priority     TaskPriority        @default(NORMAL)
  assigneeId   String?
  assignee     User?               @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  createdById  String
  createdBy    User                @relation("TaskCreator", fields: [createdById], references: [id], onDelete: Restrict)
  plannedHours Float?
  dueDate      DateTime?
  completedAt  DateTime?
  position     Int                 @default(0)
  checklist    TaskChecklistItem[]
  comments     TaskComment[]
  timeEntries  TimeEntry[]
  documents    Document[]
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  @@index([companyId])
  @@index([projectId, status, position])
  @@index([assigneeId])
}

model TaskChecklistItem {
  id        String   @id @default(uuid())
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  text      String
  done      Boolean  @default(false)
  position  Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([taskId, position])
}

model TaskComment {
  id        String   @id @default(uuid())
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Restrict)
  comment   String
  createdAt DateTime @default(now())

  @@index([taskId, createdAt])
}

enum DocumentCategory {
  OFFER
  ORDER
  INVOICE
  DELIVERY_NOTE
  TEST_REPORT
  PLAN
  PHOTO
  OTHER
}

model Document {
  id           String           @id @default(uuid())
  companyId    String
  company      Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  projectId    String
  project      Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  taskId       String?
  task         Task?            @relation(fields: [taskId], references: [id], onDelete: SetNull)
  diaryEntryId String?
  diaryEntry   DiaryEntry?      @relation(fields: [diaryEntryId], references: [id], onDelete: SetNull)
  uploadedById String
  uploadedBy   User             @relation(fields: [uploadedById], references: [id], onDelete: Restrict)
  groupId      String
  version      Int              @default(1)
  name         String
  originalName String
  storageName  String
  mimeType     String
  size         Int
  category     DocumentCategory @default(OTHER)
  description  String?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  @@unique([groupId, version])
  @@index([companyId])
  @@index([projectId, category, createdAt])
  @@index([taskId])
  @@index([diaryEntryId])
  @@index([groupId])
}

enum MaterialUnit {
  PIECE
  METER
  SQUARE_METER
  KILOGRAM
  LITER
  PACKAGE
  ROLL
  OTHER
}

enum MaterialBookingType {
  CONSUMPTION
  RETURN
}

model Material {
  id            String            @id @default(uuid())
  companyId     String
  company       Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  articleNumber String
  name          String
  description   String?
  manufacturer  String?
  unit          MaterialUnit      @default(PIECE)
  purchasePrice Decimal?          @db.Decimal(12, 2)
  salesPrice    Decimal?          @db.Decimal(12, 2)
  stockQuantity Decimal           @default(0) @db.Decimal(14, 3)
  minimumStock  Decimal           @default(0) @db.Decimal(14, 3)
  active        Boolean           @default(true)
  bookings      MaterialBooking[]
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@unique([companyId, articleNumber])
  @@index([companyId, name])
}

model MaterialBooking {
  id         String              @id @default(uuid())
  companyId  String
  company    Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  projectId  String
  project    Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  materialId String
  material   Material            @relation(fields: [materialId], references: [id], onDelete: Restrict)
  bookedById String
  bookedBy   User                @relation(fields: [bookedById], references: [id], onDelete: Restrict)
  type       MaterialBookingType @default(CONSUMPTION)
  quantity   Decimal             @db.Decimal(14, 3)
  unitPrice  Decimal?            @db.Decimal(12, 2)
  note       String?
  bookedAt   DateTime            @default(now())
  createdAt  DateTime            @default(now())

  @@index([companyId])
  @@index([projectId, bookedAt])
  @@index([materialId])
}
